    "\n",
    "# print(\"=== ΤΕΛΙΚΟΣ ΕΛΕΓΧΟΣ ΜΟΝΤΕΛΟΥ ===\")\n",
    "# print(\"Είσοδος (Εικόνες):\", images_batch.shape)\n",
    "# print(\"Έξοδος (Προβλέψεις Μάσκας):\", predicted_masks.shape)\n",
